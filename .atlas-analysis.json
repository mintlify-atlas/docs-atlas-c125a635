  "projectName": "RAADS-R Self-Host",
  "projectDescription": "Self-hosted, offline-first RAADS-R autism screening questionnaire with 80 items, domain scoring, and export functionality.",
  "theme": "almond",
  "primaryColor": "#3b82f6",
  "lightColor": "#60a5fa",
