  },
  "keyFeatures": [
    "80-item RAADS-R questionnaire with exact clinical wording",
    "Four domain scoring (Social Relatedness, Circumscribed Interests, Language, Sensory Motor)",
    "Offline-first with optional localStorage persistence",
    "Export results as JSON, CSV, or PDF",
    "Dark/light mode with system preference detection",
    "Print-friendly results view",
    "Fully accessible with keyboard navigation",
    "No tracking, no backend, no external requests"
  ],
  "publicApiSurface": [
    "scoreItem(responseIndex, isNormative)",
    "computeResults(responses, dataset)",
    "exportJSON(responses, results, dataset)",
    "exportCSV(responses, results, dataset)",
    "exportPDF(responses, results, dataset)",
    "useQuizState(dataset)",
    "useDarkMode()",
    "useLocalStorage(key, initialValue)"
  ]
}
